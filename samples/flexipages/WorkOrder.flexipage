    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>actionNames</name>
                    <valueList>
                        <valueListItems>
                            <value>Submit</value>
                            <visibilityRule>
                                <booleanFilter>((1 AND 5) OR 2) AND 3 AND 4</booleanFilter>
                                <criteria>
                                    <leftValue>{!Record.Status}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>Raised</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.Sub_Milestone__c}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>SUPW2 Requested</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.LineItemCount}</leftValue>
                                    <operator>GT</operator>
                                    <rightValue>0</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.Work_Priority__r.Name}</leftValue>
                                    <operator>NE</operator>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.ParentWorkOrder.Record_Type_developer_Name__c}</leftValue>
                                    <operator>NE</operator>
                                    <rightValue>Jobs</rightValue>
                                </criteria>
                            </visibilityRule>
                        </valueListItems>
