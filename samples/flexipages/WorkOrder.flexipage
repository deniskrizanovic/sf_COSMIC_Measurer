    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>actionNames</name>
                    <valueList>
                        <valueListItems>
                            <value>Submit</value>
                            <visibilityRule>
                                <booleanFilter>1 AND 4 AND  ( 2 OR (5 AND 6)) AND 3</booleanFilter>
                                <criteria>
                                    <leftValue>{!Record.Status}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>Raised</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.SUI_Active_Line_Items__c}</leftValue>
                                    <operator>GT</operator>
                                    <rightValue>0</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.SUI_Work_Priority__r.Name}</leftValue>
                                    <operator>NE</operator>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.ParentWorkOrder.SUI_Record_Type_developer_Name__c}</leftValue>
                                    <operator>NE</operator>
                                    <rightValue>SUI_Jobs</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.LineItemCount}</leftValue>
                                    <operator>GT</operator>
                                    <rightValue>2</rightValue>
                                </criteria>
                                <criteria>
                                    <leftValue>{!Record.SUI_Record_Type_developer_Name__c}</leftValue>
                                    <operator>EQUAL</operator>
                                    <rightValue>SUI_Programmed</rightValue>
                                </criteria>
